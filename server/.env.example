AGORA_APP_ID=your-app-id
AGORA_APP_CERTIFICATE=your-app-certificate
# Optional: enable HMAC-SHA256 verification of Agora NCS webhook signatures.
# This is the NCS secret from Agora Console → Notifications (NOT an LLM/provider key).
# AGORA_NOTIFICATION_SECRET=
# Optional: where received events are stored (ephemeral by default).
# WEBHOOKS_DB_PATH=/tmp/webhooks.db
# Optional: only if your account requires a BYO OpenAI key (managed OpenAI is keyless).
# OPENAI_API_KEY=
